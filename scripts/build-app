#!/usr/bin/env bash

set -euo pipefail

source "$(cd -- "$(dirname -- "$0")" && pwd)/common.sh"

require_command xcodebuild

PROJECT_PATH="$REPO_ROOT/Projects/App/BeanTrackerApp.xcodeproj"
RUN_DERIVED_DATA="$DERIVED_DATA_ROOT/app"

mkdir -p "$RUN_DERIVED_DATA"

xcodebuild \
    -project "$PROJECT_PATH" \
    -scheme "BeanTrackerApp" \
    -derivedDataPath "$RUN_DERIVED_DATA" \
    -destination "generic/platform=iOS" \
    CODE_SIGNING_ALLOWED=NO \
    build
